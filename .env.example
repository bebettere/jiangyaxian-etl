# Feishu / Lark app credentials.
# Create an internal app in Feishu Developer Console, then copy App ID and App Secret.
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Feishu Base / Bitable identifiers.
# FEISHU_TABLE_APP_TOKEN is the Base app token in the URL.
# FEISHU_TABLE_ID is the table id inside that Base.
FEISHU_TABLE_APP_TOKEN=
FEISHU_TABLE_ID=

# Feishu chat id for historical group messages.
# The app must have IM message history permissions and be allowed in the chat.
FEISHU_CHAT_ID=

# OpenAI-compatible credentials for gpt-5.4 (vision + extraction) and
# text-embedding-3-small (embeddings). If unset, LLMClient falls back to
# reading the locally-configured OpenClaw credentials at
# ~/.openclaw/agents/main/agent/auth-profiles.json and
# ~/.openclaw/openclaw.json — leave these blank when running on the same
# host as OpenClaw.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Optional model overrides.
OPENAI_CHAT_MODEL=gpt-5.4
OPENAI_VISION_MODEL=gpt-5.4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Runtime paths.
DATABASE_PATH=data/knowledge.db
IMAGE_DIR=data/images
